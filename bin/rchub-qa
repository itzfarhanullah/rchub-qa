#!/usr/bin/env node

import { Command } from 'commander';
import { search } from '../src/commands/search.js';
import { get } from '../src/commands/get.js';
import { list } from '../src/commands/list.js';
import { annotate } from '../src/commands/annotate.js';

const program = new Command();

program
  .name('rchub-qa')
  .description('Curated, token-efficient QA documentation for AI coding agents')
  .version('0.1.0');

program
  .command('list')
  .description('List all available QA docs')
  .action(list);

program
  .command('search <query>')
  .description('Search docs by keyword (e.g. "e2e testing", "playwright", "api")')
  .action(search);

program
  .command('get <id>')
  .description('Fetch a specific doc (e.g. playwright/testing)')
  .option('--lang <lang>', 'Language: py, js, python, javascript')
  .action(get);

program
  .command('annotate [id] [note]')
  .description('Add or view annotations for a doc')
  .option('--list', 'List all annotations')
  .option('--import <file>', 'Import annotations from JSON file')
  .option('--export', 'Export all annotations as JSON')
  .action(annotate);

program.parse();
